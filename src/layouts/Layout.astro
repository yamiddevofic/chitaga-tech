---
import '../styles/global.css';

const {
    title = "Chitagá Tech | Comunidad de Tecnología e Innovación en Chitagá, Norte de Santander",
    description = "Primera comunidad educativa de tecnología en Chitagá, Norte de Santander. Cursos gratuitos de programación, talleres prácticos, meetups y mentoría para jóvenes y adultos.",
    image = "/parque.jpg",
} = Astro.props;

const siteUrl = Astro.site || new URL(Astro.url.origin);
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl);

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Chitagá Tech",
    "url": canonicalURL.href,
    "logo": new URL("/favicon.ico", siteUrl).href,
    "description": description,
    "address": {
        "@type": "PostalAddress",
        "addressLocality": "Chitagá",
        "addressRegion": "Norte de Santander",
        "addressCountry": "CO"
    },
    "sameAs": []
};
---
<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <meta name="author" content="Comunidad Chitagá Tech" />
        <meta name="robots" content="index, follow" />
        <meta name="theme-color" content="#184014" />
        <meta name="keywords" content="tecnología Chitagá, programación Norte de Santander, cursos tecnología Chitagá, comunidad tech Colombia, aprender programación gratis, talleres digitales Chitagá" />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:locale" content="es_CO" />
        <meta property="og:site_name" content="Chitagá Tech" />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalURL} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />

        <!-- Favicon & Apple Touch -->
        <link rel="icon" href="/favicon.ico" sizes="32x32" />
        <link rel="apple-touch-icon" href="/favicon.ico" />

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=Poppins:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">

        <!-- Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </head>
	<body>
		<div id="container">
        <header id="site-header">
            <div class="header-inner">
                <a href="#inicio" class="header-brand">
                    <img src="/favicon.ico" alt="Chitaga Tech" class="header-icon" />
                    <span class="header-name">Chitaga Tech</span>
                </a>

                <!-- Nav desktop -->
                <nav class="nav-desktop">
                    <ul>
                        <li><a href="#inicio" class="nav-link active">Inicio</a></li>
                        <li><a href="#nosotros" class="nav-link">Nosotros</a></li>
                        <li><a href="#servicios" class="nav-link">Servicios</a></li>
                        <li><a href="#proyectos" class="nav-link">Proyectos</a></li>
                        <li><a href="#contacto" class="nav-link">Contacto</a></li>
                    </ul>
                </nav>

                <!-- Hamburger button -->
                <button id="menu-toggle" aria-label="Abrir menú" aria-expanded="false">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </header>

        <!-- Mobile overlay menu -->
        <div id="mobile-overlay" class="mobile-overlay">
            <nav class="mobile-nav">
                <ul>
                    <li><a href="#inicio">Inicio</a></li>
                    <li><a href="#nosotros">Nosotros</a></li>
                    <li><a href="#servicios">Servicios</a></li>
                    <li><a href="#proyectos">Proyectos</a></li>
                    <li><a href="#contacto">Contacto</a></li>
                </ul>
            </nav>
        </div>

        <script>
            const toggle = document.getElementById('menu-toggle');
            const overlay = document.getElementById('mobile-overlay');
            const body = document.body;

            toggle?.addEventListener('click', () => {
                const isOpen = toggle.classList.contains('is-active');
                toggle.classList.toggle('is-active');
                overlay?.classList.toggle('is-open');
                body.style.overflow = isOpen ? '' : 'hidden';
                toggle.setAttribute('aria-expanded', String(!isOpen));
            });

            // Close menu on link click
            overlay?.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    toggle?.classList.remove('is-active');
                    overlay?.classList.remove('is-open');
                    body.style.overflow = '';
                    toggle?.setAttribute('aria-expanded', 'false');
                });
            });

            // Header: transparente arriba, glassmorphism al scrollear
            const header = document.getElementById('site-header');
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) {
                    header?.classList.add('scrolled');
                } else {
                    header?.classList.remove('scrolled');
                }
            });
        </script>
        <main>
			<slot />
        </main>
        <footer id="site-footer">
            <div class="footer-inner">
                <!-- Brand -->
                <div class="footer-brand">
                    <div class="footer-logo">
                        <img src="/favicon.ico" alt="Chitaga Tech" class="footer-icon" />
                        <span class="footer-name">Chitaga Tech</span>
                    </div>
                    <p class="footer-tagline">Innovación y tecnología para nuestra comunidad.</p>
                </div>

                <!-- Links -->
                <div class="footer-links">
                    <div class="footer-col">
                        <h4>Navegación</h4>
                        <ul>
                            <li><a href="#inicio">Inicio</a></li>
                            <li><a href="#nosotros">Nosotros</a></li>
                            <li><a href="#servicios">Servicios</a></li>
                            <li><a href="#proyectos">Proyectos</a></li>
                            <li><a href="#contacto">Contacto</a></li>
                        </ul>
                    </div>
                    <div class="footer-col">
                        <h4>Redes</h4>
                        <ul>
                            <li><a href="#" aria-label="Facebook">Facebook</a></li>
                            <li><a href="#" aria-label="Instagram">Instagram</a></li>
                            <li><a href="#" aria-label="GitHub">GitHub</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Divider + copyright -->
            <div class="footer-bottom">
                <p>&copy; 2026 Chitaga Tech. Todos los derechos reservados.</p>
            </div>
        </footer>
    </div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
