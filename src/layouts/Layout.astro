---
import '../styles/global.css';
import { navLinks } from '../data/navigation.js';
import { siteConfig } from '../data/site.js';

const {
    title = "Chitagá Tech — Que irse sea opción, no obligación | Comunidad Tech en Chitagá, Norte de Santander",
    description = "Comunidad de profesionales chitagüenses que construyen oportunidades reales en tecnología. Cursos de programación, talleres digitales, mentoría y proyectos para que quedarte en Chitagá sea una elección, no una limitación.",
    image = "/og-image.png",
    ogType = "website",
} = Astro.props;

const siteUrl = new URL(siteConfig.url);
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl);
const ogImageType = image.endsWith('.jpg') || image.endsWith('.jpeg') ? 'image/jpeg' : 'image/png';

const jsonLd = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": siteConfig.name,
    "alternateName": siteConfig.alternateName,
    "url": siteConfig.url,
    "logo": new URL("/favicon.ico", siteUrl).href,
    "description": siteConfig.description,
    "slogan": siteConfig.slogan,
    "foundingLocation": {
        "@type": "Place",
        "name": `${siteConfig.location.locality}, ${siteConfig.location.region}, Colombia`
    },
    "address": {
        "@type": "PostalAddress",
        "addressLocality": siteConfig.location.locality,
        "addressRegion": siteConfig.location.region,
        "addressCountry": siteConfig.location.country
    },
    "areaServed": {
        "@type": "Place",
        "name": `${siteConfig.location.locality}, ${siteConfig.location.region}`
    },
    "knowsAbout": siteConfig.knowsAbout,
    "sameAs": []
};
---
<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        <meta name="author" content="Comunidad Chitagá Tech" />
        <meta name="robots" content="index, follow" />
        <meta name="theme-color" content="#184014" />
        <meta name="keywords" content="Chitagá Tech, tecnología Chitagá, programación Chitagá, cursos programación Norte de Santander, comunidad tech Colombia, aprender programación gratis, talleres digitales Chitagá, desarrollo web Chitagá, innovación rural Colombia, empleo tecnología Chitagá, formación digital Norte de Santander" />
        <meta name="geo.region" content="CO-NSA" />
        <meta name="geo.placename" content={`${siteConfig.location.locality}, ${siteConfig.location.region}`} />
        <meta name="geo.position" content={siteConfig.location.geoPosition} />
        <meta name="ICBM" content={siteConfig.location.geoPosition.replace(';', ', ')} />

        <!-- Open Graph -->
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalURL.href} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL.href} />
        <meta property="og:image:type" content={ogImageType} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={title} />
        <meta property="og:locale" content="es_CO" />
        <meta property="og:site_name" content={siteConfig.name} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalURL.href} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL.href} />

        <!-- Favicon & Apple Touch -->
        <link rel="icon" href="/favicon.ico" sizes="32x32" />
        <link rel="apple-touch-icon" href="/favicon.ico" />

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Open+Sans:wght@400;500;600&family=Poppins:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">

        <!-- Structured Data -->
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

        <!-- Restore theme before render to prevent flash -->
        <script is:inline>
            (function() {
                var t = localStorage.getItem('theme');
                if (!t) t = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
                if (t === 'dark') document.documentElement.classList.add('dark');
            })();
        </script>
    </head>
    <body>
        <div id="container">
            <header id="site-header">
                <div class="header-inner">
                    <a href="/" class="header-brand">
                        <img src="/favicon.ico" alt="Chitaga Tech" class="header-icon" />
                        <span class="header-name">Chitaga Tech</span>
                    </a>

                    <nav class="nav-desktop">
                        <ul>
                            {navLinks.map(({ href, label, subItems }) => (
                                <li>
                                    {subItems?.length ? (
                                        <div class="nav-dropdown">
                                            <a href={href} class="nav-link">{label}</a>
                                            <button class="nav-dropdown-toggle" aria-label={`Desplegar ${label}`} aria-expanded="false">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                    <polyline points="6 9 12 15 18 9"></polyline>
                                                </svg>
                                            </button>
                                            <ul class="submenu">
                                                {subItems.map(({ href: subHref, label: subLabel }) => (
                                                    <li><a href={subHref} class="nav-link sub-link">{subLabel}</a></li>
                                                ))}
                                            </ul>
                                        </div>
                                    ) : (
                                        <a href={href} class="nav-link">{label}</a>
                                    )}
                                </li>
                            ))}
                        </ul>
                    </nav>

                    <button id="menu-toggle" aria-label="Abrir menú" aria-expanded="false">
                        <span></span>
                        <span></span>
                        <span></span>
                    </button>
                </div>
            </header>

            <div id="mobile-overlay" class="mobile-overlay">
                <div class="mobile-overlay-header">
                    <a href="/" class="header-brand">
                        <img src="/favicon.ico" alt="Chitaga Tech" class="header-icon" />
                        <span class="header-name">Chitaga Tech</span>
                    </a>
                </div>
                <nav class="mobile-nav">
                    <ul>
                        {navLinks.map(({ href, label, subItems }) => (
                            <li>
                                <div class="mobile-link-row">
                                    <a href={href}>{label}</a>
                                    {subItems?.length && (
                                        <button class="mobile-submenu-toggle" aria-label={`Desplegar ${label}`} aria-expanded="false">
                                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="6 9 12 15 18 9"></polyline>
                                            </svg>
                                        </button>
                                    )}
                                </div>
                                {subItems?.length && (
                                    <ul class="mobile-submenu">
                                        {subItems.map(({ href: subHref, label: subLabel }) => (
                                            <li><a href={subHref}>{subLabel}</a></li>
                                        ))}
                                    </ul>
                                )}
                            </li>
                        ))}
                    </ul>
                </nav>
                <div class="mobile-overlay-footer">
                    <p>Chitagá Tech &mdash; Que irse sea opción, no obligación.</p>
                </div>
            </div>

            <script>
                import '../scripts/header.js';
            </script>

            <main>
                <slot />
            </main>

            <footer id="site-footer">
                <div class="footer-inner">
                    <div class="footer-brand">
                        <div class="footer-logo">
                            <img src="/favicon.ico" alt="Chitaga Tech" class="footer-icon" />
                            <span class="footer-name">Chitaga Tech</span>
                        </div>
                        <p class="footer-tagline">Para que irse sea opción, no obligación.</p>
                    </div>

                    <div class="footer-links">
                        <div class="footer-col">
                            <h4>Navegación</h4>
                            <ul>
                                {navLinks.map(({ href, label }) => (
                                    <li><a href={href}>{label}</a></li>
                                ))}
                            </ul>
                        </div>
                        <div class="footer-col">
                            <h4>Redes</h4>
                            <ul>
                                <li><a href="#">Facebook</a></li>
                                <li><a href="#">Instagram</a></li>
                                <li><a href="#">GitHub</a></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="footer-bottom">
                    <p>&copy; 2026 Chitaga Tech. Todos los derechos reservados.</p>
                </div>
            </footer>
        </div>
    </body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
