---
import ScrollAnimation from './ScrollAnimation.jsx';
---

<section id="nosotros" class="about-section">
    <div class="about-inner">
        <ScrollAnimation className="about-text" delay={0.2} client:load as="div">
            <span class="about-badge">La propuesta</span>
            <h2 class="about-title">¿Por qué una comunidad tech en Chitagá?</h2>
            <p class="about-description">
                <strong>Chitaga Tech</strong> nace de una idea sencilla: que el acceso a la tecnología
                no debería depender del lugar donde vives. Queremos crear un espacio donde cualquier persona
                de Chitagá pueda aprender, practicar y crecer en el mundo digital.
            </p>
            <div class="about-mission">
                <ScrollAnimation delay={0.4} variants={{
                    hidden: { opacity: 0, x: -30 },
                    visible: { opacity: 1, x: 0 }
                }} client:load as="div">
                    <div class="about-card">
                        <svg class="about-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"/>
                            <path d="M12 16v-4M12 8h.01"/>
                        </svg>
                        <div>
                            <h3>Nuestra misión</h3>
                            <p>Crear espacios de aprendizaje accesibles y colaborativos donde cualquier persona pueda dar sus primeros pasos en tecnología.</p>
                        </div>
                    </div>
                </ScrollAnimation>
                <ScrollAnimation delay={0.6} variants={{
                    hidden: { opacity: 0, x: -30 },
                    visible: { opacity: 1, x: 0 }
                }} client:load as="div">
                    <div class="about-card">
                        <svg class="about-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <div>
                            <h3>A dónde queremos llegar</h3>
                            <p>Convertirnos en el referente de innovación tecnológica en nuestra región, impulsando proyectos que transformen vidas.</p>
                        </div>
                    </div>
                </ScrollAnimation>
            </div>
        </ScrollAnimation>
        <ScrollAnimation delay={0.3} variants={{
            hidden: { opacity: 0, rotate: -10 },
            visible: { opacity: 1, rotate: 0 }
        }} client:load as="div">
            <div class="about-visual">
                <div class="about-graphic">
                    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="100" cy="100" r="80" stroke="currentColor" stroke-width="1.5" opacity="0.2"/>
                        <circle cx="100" cy="100" r="55" stroke="currentColor" stroke-width="1.5" opacity="0.3"/>
                        <circle cx="100" cy="100" r="30" fill="currentColor" opacity="0.1"/>
                        <circle cx="100" cy="50" r="8" fill="var(--color-orange)"/>
                        <circle cx="145" cy="120" r="8" fill="var(--color-green-light)"/>
                        <circle cx="55" cy="120" r="8" fill="var(--color-orange)"/>
                        <line x1="100" y1="58" x2="140" y2="114" stroke="currentColor" stroke-width="1" opacity="0.3"/>
                        <line x1="100" y1="58" x2="60" y2="114" stroke="currentColor" stroke-width="1" opacity="0.3"/>
                        <line x1="62" y1="120" x2="138" y2="120" stroke="currentColor" stroke-width="1" opacity="0.3"/>
                        <text x="100" y="105" text-anchor="middle" font-family="var(--font-montserrat)" font-size="14" font-weight="700" fill="currentColor" opacity="0.6">CT</text>
                    </svg>
                </div>
            </div>
        </ScrollAnimation>
    </div>
</section>

<style>
    .about-section {
        padding: 5rem 2rem;
        background: #ffffff;
    }

    :global(.dark) .about-section {
        background: #191919;
    }

    @media (min-width: 768px) {
        .about-section {
            padding: 6rem 3rem;
        }
    }

    @media (min-width: 1024px) {
        .about-section {
            padding: 8rem 4rem;
        }
    }

    .about-inner {
        max-width: 1080px;
        margin: 0 auto;
        display: grid;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .about-inner {
            flex-direction: row;
            align-items: center;
            gap: 5rem;
        }
    }

    .about-text {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .about-badge {
        display: inline-block;
        width: fit-content;
        padding: 0.3rem 0.85rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 9999px;
        color: var(--color-green-dark);
        border: 1px solid var(--color-green-dark);
        font-family: var(--font-pop);
    }

    :global(.dark) .about-badge {
        color: var(--color-orange);
        border-color: var(--color-orange);
    }

    .about-title {
        font-family: var(--font-montserrat);
        font-weight: 700;
        font-size: 1.75rem;
        line-height: 1.2;
        color: var(--color-green-dark);
    }

    :global(.dark) .about-title {
        color: var(--color-white);
    }

    @media (min-width: 768px) {
        .about-title {
            font-size: 2.25rem;
        }
    }

    .about-description {
        font-family: var(--font-sans);
        font-size: 1rem;
        line-height: 1.7;
        color: #4b5563;
        max-width: 540px;
    }

    :global(.dark) .about-description {
        color: #d1d5db;
    }

    .about-description strong {
        color: var(--color-green-dark);
        font-weight: 600;
    }

    :global(.dark) .about-description strong {
        color: var(--color-orange);
    }

    .about-mission {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-top: 0.5rem;
    }

    .about-card {
        display: flex;
        gap: 1.25rem;
        padding: 1.5rem;
        border-radius: 0.75rem;
        border: 1px solid rgba(0, 0, 0, 0.08);
        background: rgba(0, 0, 0, 0.02);
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    :global(.dark) .about-card {
        border-color: rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
    }

    .about-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    }

    :global(.dark) .about-card:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
    }

    .about-icon {
        width: 2rem;
        height: 2rem;
        flex-shrink: 0;
        color: var(--color-orange);
        margin-top: 0.15rem;
    }

    .about-card h3 {
        font-family: var(--font-montserrat);
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--color-green-dark);
        margin-bottom: 0.35rem;
    }

    :global(.dark) .about-card h3 {
        color: var(--color-white);
    }

    .about-card p {
        font-family: var(--font-sans);
        font-size: 0.875rem;
        line-height: 1.6;
        color: #6b7280;
    }

    :global(.dark) .about-card p {
        color: #9ca3af;
    }

    /* Visual / Graphic */
    .about-visual {
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    @media (min-width: 768px) {
        .about-visual {
            width: 280px;
        }
    }

    @media (min-width: 1024px) {
        .about-visual {
            width: 340px;
        }
    }

    .about-graphic {
        width: 200px;
        height: 200px;
        color: var(--color-green-dark);
    }

    :global(.dark) .about-graphic {
        color: var(--color-white);
    }

    @media (min-width: 768px) {
        .about-graphic {
            width: 260px;
            height: 260px;
        }
    }

    .about-graphic svg {
        width: 100%;
        height: 100%;
    }
</style>
