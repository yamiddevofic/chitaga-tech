---
import ScrollAnimation from './ScrollAnimation.jsx';

interface Props {
    title?: string;
    subtitle?: string;
    cta?: string;
    ctaHref?: string;
    imgSrc?: string;
    imgDarkSrc?: string;
    imgAlt?: string;
}

const {
    title = "Tu futuro no debería depender de irte de Chitagá",
    subtitle = "Somos profesionales chitagüenses construyendo el primer espacio de tecnología hecho por y para nuestra gente. Para que quedarte sea una elección, no una limitación.",
    cta = "Quiero ser parte",
    ctaHref = "#contacto",
    imgSrc = "/parque.jpg",
    imgDarkSrc = "/parque.jpg",
    imgAlt = "Chitagá, Norte de Santander",
} = Astro.props;
---

<section id="inicio" class="hero-section">
    <div class="hero-inner">
        <ScrollAnimation className="hero-content" delay={0.2} client:load as="div">
            <span class="hero-badge">De Chitagüenses, para Chitagüenses</span>
            <h1 class="hero-title">{title}</h1>
            <p class="hero-subtitle">{subtitle}</p>
            <div class="hero-actions">
                <a href={ctaHref} class="hero-cta">{cta}</a>
                <a href="#nosotros" class="hero-cta-secondary">Conoce por qué lo hacemos &rarr;</a>
            </div>
        </ScrollAnimation>

        <ScrollAnimation className="hero-image-col" delay={0.4} variants={{
            hidden: { opacity: 0, scale: 0.95 },
            visible: { opacity: 1, scale: 1 }
        }} client:load as="div">
            <div class="hero-image-wrapper">
                <img src={imgSrc} alt={imgAlt} class="hero-img hero-img-light" loading="eager" />
                <img src={imgDarkSrc} alt={imgAlt} class="hero-img hero-img-dark" loading="eager" />
                <div class="hero-image-overlay"></div>
            </div>
        </ScrollAnimation>
    </div>
</section>

<style>
    /* Light/dark image toggle */
    .hero-img-light { display: block; }
    .hero-img-dark  { display: none;  }
    :global(.dark) .hero-img-light { display: none;  }
    :global(.dark) .hero-img-dark  { display: block; }

    .hero-section {
        padding: 0;
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center;
        background: #ffffff;
        overflow: hidden;
    }

    :global(.dark) .hero-section {
        background: #191919;
    }

    @media (min-width: 1024px) {
        .hero-section {
            padding-left: max(4rem, calc((100vw - 1200px) / 2));
        }
    }

    .hero-inner {
        width: 100%;
        display: grid;
        gap: 0;
        align-items: center;
    }

    @media (min-width: 768px) {
        .hero-inner {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (min-width: 1024px) {
        .hero-inner {
            max-width: none;
            grid-template-columns: 1fr 50vw;
        }
    }

    /* Content — :global() needed because this class is on a React-rendered element */
    :global(.hero-content) {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        align-items: flex-start;
        text-align: left;
        padding: 3rem 2rem;
        order: 1;
    }

    @media (min-width: 768px) {
        :global(.hero-content) {
            padding: 4rem 3rem;
        }
    }

    @media (min-width: 1024px) {
        :global(.hero-content) {
            padding: 4rem 3rem 4rem 0;
        }
    }

    /* Badge */
    .hero-badge {
        display: inline-block;
        width: fit-content;
        padding: 0.3rem 0.85rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        border-radius: 9999px;
        color: var(--color-green-dark);
        border: 1px solid var(--color-green-dark);
        font-family: var(--font-pop);
    }

    :global(.dark) .hero-badge {
        color: var(--color-orange);
        border-color: var(--color-orange);
    }

    @media (min-width: 1024px) {
        .hero-badge {
            font-size: 0.75rem;
        }
    }

    /* Title */
    .hero-title {
        font-family: var(--font-montserrat);
        font-weight: 700;
        line-height: 1.1;
        font-size: 2.25rem;
        color: var(--color-green-dark);
    }

    :global(.dark) .hero-title {
        color: var(--color-white);
    }

    @media (min-width: 640px) {
        .hero-title { font-size: 2.75rem; }
    }
    @media (min-width: 768px) {
        .hero-title { font-size: 3rem; }
    }
    @media (min-width: 1024px) {
        .hero-title { font-size: 3rem; }
    }
    @media (min-width: 1280px) {
        .hero-title { font-size: 3.25rem; }
    }

    /* Subtitle */
    .hero-subtitle {
        font-family: var(--font-sans);
        font-size: 1rem;
        line-height: 1.7;
        color: #4b5563;
        max-width: 28rem;
    }

    :global(.dark) .hero-subtitle {
        color: #d1d5db;
    }

    @media (min-width: 768px) {
        .hero-subtitle { font-size: 1.125rem; }
    }

    /* Actions */
    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 1.25rem;
        margin-top: 1rem;
    }

    @media (min-width: 768px) {
        .hero-actions {
            justify-content: flex-start;
        }
    }

    .hero-cta {
        display: inline-block;
        padding: 0.75rem 2rem;
        background: var(--color-orange);
        color: #fff;
        font-family: var(--font-pop);
        font-weight: 600;
        font-size: 0.9rem;
        border-radius: 0.5rem;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }

    .hero-cta:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(185, 58, 5, 0.3);
    }

    .hero-cta-secondary {
        display: inline-block;
        padding: 0.75rem 0.5rem;
        font-family: var(--font-pop);
        font-weight: 500;
        font-size: 0.9rem;
        color: var(--color-green-dark);
        transition: color 0.2s ease;
    }

    :global(.dark) .hero-cta-secondary {
        color: var(--color-white);
    }

    .hero-cta-secondary:hover {
        color: var(--color-orange);
    }

    /* Image column */
    :global(.hero-image-col) {
        width: 100%;
        order: 2;
    }

    @media (min-width: 768px) {
        :global(.hero-image-col) {
            height: 100%;
        }
    }

    /* Image */
    .hero-image-wrapper {
        position: relative;
        width: 100%;
        overflow: hidden;
        aspect-ratio: 4 / 3;
    }

    @media (min-width: 768px) {
        .hero-image-wrapper {
            aspect-ratio: auto;
            height: calc(100vh - 64px);
            border-radius: 0;
        }
    }

    .hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Gradient overlay — mobile: fog from top; desktop: left fade */
    .hero-image-overlay {
        position: absolute;
        inset: 0;
        pointer-events: none;
        background: linear-gradient(
            to bottom,
            #ffffff 0%,
            rgba(255, 255, 255, 0.5) 15%,
            transparent 40%
        );
    }

    :global(.dark) .hero-image-overlay {
        background: linear-gradient(
            to bottom,
            #191919 0%,
            rgba(25, 25, 25, 0.5) 15%,
            transparent 40%
        );
    }

    @media (min-width: 768px) {
        .hero-image-overlay {
            background: linear-gradient(
                to right,
                #ffffff 0%,
                rgba(255, 255, 255, 0.5) 10%,
                transparent 30%
            );
        }

        :global(.dark) .hero-image-overlay {
            background: linear-gradient(
                to right,
                #191919 0%,
                rgba(25, 25, 25, 0.5) 10%,
                transparent 30%
            );
        }
    }
</style>
